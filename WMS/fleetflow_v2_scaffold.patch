+name: CI
+
+on:
+  pull_request:
+    branches: [main]
+  push:
+    branches: [main]
+
+concurrency:
+  group: ci-${{ github.ref }}
+  cancel-in-progress: true
+
+env:
+  NODE_VERSION: '20.x'
+  NEXT_TELEMETRY_DISABLED: '1'
+
+jobs:
+  lint-types-prisma:
+    name: Lint, Types, Prisma
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    services:
+      postgres:
+        image: postgres:16
+        env:
+          POSTGRES_PASSWORD: postgres
+          POSTGRES_DB: fleetflow_test
+        ports: ['5432:5432']
+        options: >-
+          --health-cmd pg_isready
+          --health-interval 10s
+          --health-timeout 5s
+          --health-retries 5
+    env:
+      DATABASE_URL: postgresql://postgres:postgres@localhost:5432/fleetflow_test
+      DIRECT_URL: postgresql://postgres:postgres@localhost:5432/fleetflow_test
+    steps:
+      - uses: actions/checkout@v4
+        with: { fetch-depth: 0 }
+      - uses: actions/setup-node@v4
+        with:
+          node-version: ${{ env.NODE_VERSION }}
+          cache: 'npm'
+      - run: npm ci
+      - name: ESLint
+        run: npm run lint -- --max-warnings=0
+      - name: TypeScript
+        run: npx tsc --noEmit
+      - name: Prisma format check
+        run: npx prisma format && git diff --exit-code prisma/schema.prisma
+      - name: Prisma validate
+        run: npx prisma validate
+      - name: Prisma migrate deploy
+        run: npx prisma migrate deploy
+      - name: Prisma migrate diff (assert no drift)
+        run: |
+          npx prisma migrate diff \
+            --from-schema-datamodel prisma/schema.prisma \
+            --to-schema-datasource prisma/schema.prisma \
+            --exit-code
+
+  test:
+    name: Vitest unit + integration
+    runs-on: ubuntu-latest
+    needs: lint-types-prisma
+    timeout-minutes: 15
+    services:
+      postgres:
+        image: postgres:16
+        env:
+          POSTGRES_PASSWORD: postgres
+          POSTGRES_DB: fleetflow_test
+        ports: ['5432:5432']
+        options: >-
+          --health-cmd pg_isready --health-interval 10s
+          --health-timeout 5s --health-retries 5
+    env:
+      DATABASE_URL: postgresql://postgres:postgres@localhost:5432/fleetflow_test
+      DIRECT_URL: postgresql://postgres:postgres@localhost:5432/fleetflow_test
+      CLERK_SECRET_KEY: sk_test_dummy
+      NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: pk_test_dummy
+      STRIPE_SECRET_KEY: sk_test_dummy
+      STRIPE_WEBHOOK_SECRET: whsec_dummy
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
+        with: { node-version: '20.x', cache: 'npm' }
+      - run: npm ci
+      - run: npx prisma generate
+      - run: npx prisma migrate deploy
+      - run: npm run test:unit -- --coverage
+      - run: npm run test:integration
+      - uses: actions/upload-artifact@v4
+        if: always()
+        with: { name: coverage, path: coverage/ }
+
+  e2e:
+    name: Playwright smoke
+    runs-on: ubuntu-latest
+    needs: lint-types-prisma
+    timeout-minutes: 25
+    services:
+      postgres:
+        image: postgres:16
+        env:
+          POSTGRES_PASSWORD: postgres
+          POSTGRES_DB: fleetflow_test
+        ports: ['5432:5432']
+        options: >-
+          --health-cmd pg_isready --health-interval 10s
+          --health-timeout 5s --health-retries 5
+    env:
+      DATABASE_URL: postgresql://postgres:postgres@localhost:5432/fleetflow_test
+      DIRECT_URL: postgresql://postgres:postgres@localhost:5432/fleetflow_test
+      CLERK_SECRET_KEY: sk_test_dummy
+      NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: pk_test_dummy
+      STRIPE_SECRET_KEY: sk_test_dummy
+      STRIPE_WEBHOOK_SECRET: whsec_dummy
+      NEXT_PUBLIC_APP_URL: http://localhost:3000
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
+        with: { node-version: '20.x', cache: 'npm' }
+      - run: npm ci
+      - run: npx prisma generate && npx prisma migrate deploy && npm run db:seed:smoke
+      - run: npx playwright install --with-deps chromium
+      - run: npm run build
+      - name: Start app + run Playwright
+        run: |
+          npm run start &
+          npx wait-on http://localhost:3000/api/health
+          npx playwright test --grep @smoke
+      - uses: actions/upload-artifact@v4
+        if: failure()
+        with: { name: playwright-report, path: playwright-report/ }
+
+  snyk:
+    name: Snyk dependency scan (soft-fail)
+    runs-on: ubuntu-latest
+    continue-on-error: true # flip to false once SNYK_TOKEN is provisioned and baseline is clean
+    steps:
+      - uses: actions/checkout@v4
+      - uses: snyk/actions/node@master
+        env:
+          SNYK_TOKEN: ${{ secrets.SNYK_TOKEN }}
+        with:
+          args: --severity-threshold=high --all-projects
+
+  lighthouse:
+    name: Lighthouse CI
+    runs-on: ubuntu-latest
+    needs: e2e
+    if: github.event_name == 'pull_request'
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
+        with: { node-version: '20.x', cache: 'npm' }
+      - run: npm ci && npm run build
+      - run: npm install -g @lhci/cli@0.13.x
+      - name: Run LHCI
+        env:
+          LHCI_GITHUB_APP_TOKEN: ${{ secrets.LHCI_GITHUB_APP_TOKEN }}
+        run: |
+          lhci autorun \
+            --collect.startServerCommand="npm run start" \
+            --collect.url=http://localhost:3000/dashboard \
+            --collect.url=http://localhost:3000/dispatch \
+            --collect.url=http://localhost:3000/login \
+            --assert.assertions.categories:performance=warn \
+            --assert.assertions.categories:accessibility=error
+
+  summary:
+    name: CI summary
+    runs-on: ubuntu-latest
+    needs: [lint-types-prisma, test, e2e, snyk, lighthouse]
+    if: always()
+    steps:
+      - name: Aggregate result
+        run: |
+          echo "## CI Summary" >> $GITHUB_STEP_SUMMARY
+          echo "- lint/types/prisma: ${{ needs.lint-types-prisma.result }}" >> $GITHUB_STEP_SUMMARY
+          echo "- tests: ${{ needs.test.result }}" >> $GITHUB_STEP_SUMMARY
+          echo "- e2e: ${{ needs.e2e.result }}" >> $GITHUB_STEP_SUMMARY
+          echo "- snyk: ${{ needs.snyk.result }} (soft-fail)" >> $GITHUB_STEP_SUMMARY
+          echo "- lighthouse: ${{ needs.lighthouse.result }}" >> $GITHUB_STEP_SUMMARY
+          if [[ "${{ needs.lint-types-prisma.result }}" != "success" || \
+                "${{ needs.test.result }}" != "success" || \
+                "${{ needs.e2e.result }}" != "success" ]]; then
+            exit 1
+          fi
